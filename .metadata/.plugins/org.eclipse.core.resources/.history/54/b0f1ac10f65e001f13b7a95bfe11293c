//		XGpio_DiscreteWrite(&AxiGpio_Data, FINE_CAMERA, ROI_Y_End); //写数据
//		usleep(10);
//		XGpio_DiscreteWrite(&AxiGpio_En, FINE_CAMERA, 1); //使能
//		usleep(10);
//		XGpio_DiscreteWrite(&AxiGpio_En, FINE_CAMERA, 0); //停止使能
//		usleep(10);

		sleep(1);
		//进入RUNNING模式
		XGpio_DiscreteWrite(&AxiGpio_Addr, FINE_CAMERA, CAMERA_CONFIG_ADDR); //写地址
		XGpio_DiscreteWrite(&AxiGpio_Data, FINE_CAMERA, 1025); //写数据
		usleep(1000);
		XGpio_DiscreteWrite(&AxiGpio_En, FINE_CAMERA, 1); //使能
		usleep(1000);
		XGpio_DiscreteWrite(&AxiGpio_En, FINE_CAMERA, 0); //停止使能

	}


	XGpio_DiscreteWrite(&AxiGpio_Sel, FINE_CAMERA, 0); //设置片选，停止配置相机

}

