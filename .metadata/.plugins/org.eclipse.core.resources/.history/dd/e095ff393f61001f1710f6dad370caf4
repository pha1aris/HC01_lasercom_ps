 int main()
 {
	 /*初始化模块*/

	 Can_Config();//初始化CAN
	 Uart16550_InitProc();//初始化uart16550
	 Dw_Uart_Config();//初始化迪文屏串口
	 Centroid_Gpio_Config();//初始化质心GPIO
	 DA_Gpio_Config();//初始化DA GPIO
	 Sdi_Gpio_Config();//初始化SDI选择
	 uart_init(&Uart_Ps);//初始化航姿模块
	 All_Intr_Config(); //中断初始化
	 Camera_Set_Gpio_Config();//设置相机GPIO初始化
	 Elmo_Config();   //ELmo配置


	 /*设置默认数据*/
	 Set_Coaser_Threshold(COARSE_CAMERA_THR); //设置粗相机阈值
	 Set_Fine_Threshold(FINE_CAMERA_THR);	//设置精相机阈值
	 //设置相机开窗与曝光
	 Fine_Camera_ExSet(Fine_Camera_Extime);
	 //Fine_Camera_ROI_Set(Fine_ROI_Width_Par,Fine_ROI_Width,Fine_ROI_Height_Par,Fine_ROI_Height);
	 Coarse_Camera_ExSet(Coarse_Camera_Extime);
	 //Coarse_Camera_ROI_Set(Coarse_ROI_Width_Par,Coarse_ROI_Width,Coarse_ROI_Height_Par,Coarse_ROI_Height);

	 Set_DA_Out(fine_camera_out_x,fine_camera_out_y);//设置DA默认输出
	 Dw_Systems_Config();
	 EDFA_ReadAll(EDFA_AMPLIFIER);
	 EDFA_ReadAll(EDFA_LIGHT);
	 Sdi_Show_Choice(0);
	 sleep(1);
	 while(1)
	 {
		 //usleep(100);

		 Dw_Systems_Control();  //获取迪文屏指令
		 Pro_Cnt++;
		 Sample_Work(Pro_Cnt); //迪文屏数据显示
		 if(Pro_Cnt > 100)
			 Pro_Cnt = 0;
		 //初始指向代码
		 if(Start_Point_Mark == 1)
		 {
			 if((Motor_X_Position > -0.05) && (Motor_X_Position < 0.05)
					 && (Motor_Y_Position > -0.05) &&(Motor_Y_Position < 0.05)) //电机为0，读取当前航姿信息
			 {
				 sleep(1);
				 COU_WZ = g_output_info.attitude.yaw;
				 PIT_WY = g_output_info.attitude.roll;
				 Initial_Point(g_output_info.location.longtidue,g_output_info.location.latitude,g_output_info.location.altidue,
						 	 	Peer_longtidue,Peer_latitude,Peer_altidue,
						 //114.3508882411,30.5296520593,70,
								COU_WZ,PIT_WY,0,
								0,PIT_WY,0,
								&Start_Point_Position_x,&Start_Point_Position_y);//位置解算函数

				 Elmo_Set_Position(MOTO_X_ID,Start_Point_Position_x); //初始指向X
				 Elmo_Set_Position(MOTO_Y_ID,Start_Point_Position_y); //初始指向y
				 Start_Point_Mark = 0;
			 }
		 }
		 //扫描功能代码
		 if(Start_Scan_Mark == 1) //开始扫描
		 {
			 Elmo_Set_Position(MOTO_X_ID,Scan_X_Point); //初始指向X
			 Elmo_Set_Position(MOTO_Y_ID,Scan_Y_Point); //初始指向y
			 usleep(20000); //延时20ms
			 if((coarse_camera_facula_x != 0) && (coarse_camera_facula_y != 0)) //粗跟踪相机捕获到目标，停止扫描
			 {
				 Start_Scan_Mark = 0;
			 }
			 else //没有扫描到目标，跟新指向坐标
			 {
				 Scan_X_Cnt = Scan_X_Cnt + 1;
				 if(Scan_X_Cnt == Scan_Num) //X轴扫描一行，Y移动下一行
				 {
					 Scan_X_Cnt = 0;
					 Scan_Y_Cnt = Scan_Y_Cnt + 1;
				 }
				 if(Scan_Y_Cnt == Scan_Num) //扫描结束
				 {
					 Start_Scan_Mark = 0;
				 }
				 else //跟新扫描坐标
				 {
					Scan_X_Point = Scan_X_Satrt + Scan_X_Cnt*Scan_Step;
					Scan_Y_Point = Scan_Y_Satrt + Scan_Y_Cnt*Scan_Step;
				 }
			 }
		 }


	 }

 }


 /*
