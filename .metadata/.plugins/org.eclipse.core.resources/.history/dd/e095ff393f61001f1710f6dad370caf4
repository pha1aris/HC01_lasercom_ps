  * */

 void Sample_Work(u32 Work_cnt)
 {
	 int32_t Peer_latitude_Temp;
	 int32_t Peer_longtidue_Temp;
	 int32_t Peer_altidue_Temp;

	 if(Work_cnt > 100) //1ms查询一次
	 {
////		 //测试
//		 Dw_Data_Write(PZT_V_X_ADDR,Speed_Test,4);
//		 usleep(5);
		 //粗跟踪相机光斑位置
		 Dw_Data_Write(COARSE_CAMERA_X_ADDR,coarse_camera_facula_x*1000,4);
		 usleep(20);
		 Dw_Data_Write(COARSE_CAMERA_Y_ADDR,coarse_camera_facula_y*1000,4);
		 usleep(20);
		 Dw_Coarse_Spot_P(coarse_camera_facula_x,coarse_camera_facula_y);
		 usleep(20);
		 Dw_Data_Write(COARSE_CAMERA_ERR_X_ADDR,coarse_camera_facula_x_err*1000,4);
		 usleep(20);
		 Dw_Data_Write(COARSE_CAMERA_ERR_Y_ADDR,coarse_camera_facula_y_err*1000,4);
		 usleep(20);
		 //精跟踪相机光斑位置
		 Dw_Data_Write(FINE_CAMERA_X_ADDR,fine_camera_facula_x*1000,4);
		 usleep(20);
		 Dw_Data_Write(FINE_CAMERA_Y_ADDR,fine_camera_facula_y*1000,4);
		 usleep(20);
		 Dw_Fine_Spot_P(fine_camera_facula_x,fine_camera_facula_y);
		 usleep(20);
		 Dw_Data_Write(FINE_CAMERA_ERR_X_ADDR,fine_camera_facula_x_err*1000,4);
		 usleep(20);
		 Dw_Data_Write(FINE_CAMERA_ERR_Y_ADDR,fine_camera_facula_y_err*1000,4);
		 usleep(20);
		 //显示DA输出电压值
		 Dw_Data_Write(PZT_V_X_ADDR,fine_camera_out_x*1000,4);
		 usleep(20);
		 Dw_Data_Write(PZT_V_Y_ADDR,fine_camera_out_y*1000,4);
		 usleep(20);
		 //显示电机位置
		 Dw_Data_Write(MOTOR_P_X_ADDR,Motor_X_Position*1000,4);
		 usleep(20);
		 Dw_Data_Write(MOTOR_P_Y_ADDR,Motor_Y_Position*1000,4); //显示位置
		 usleep(20);
		 //获取相机帧率
		// Camera_Rata_Read(&Fine_Rata,&Coarse_Rata);
	 	if(Yesense_data_valid == 1) //显示航姿信息
	 	{
	 		//显示航姿数据
	 		analysis_data(Yesense_buffer, Yesense_data_num, &g_output_info);
	 		Dw_Data_Write(ATT_WX_ADDR,g_output_info.attitude.pitch*1000,4);
	 		usleep(20);
	 		Dw_Data_Write(ATT_WY_ADDR,g_output_info.attitude.roll*1000,4);
	 		usleep(20);
	 		Dw_Data_Write(ATT_WZ_ADDR,g_output_info.attitude.yaw*1000,4);
	 		usleep(20);
	 		Dw_Data_Write(ATT_DIM_ADDR,g_output_info.location.latitude*1000,4);
	 		usleep(20);
	 		Dw_Data_Write(ATT_LON_ADDR,g_output_info.location.longtidue*1000,4);
	 		usleep(20);
	 		Dw_Data_Write(ATT_H_ADDR,g_output_info.location.altidue*1000,4);
	 		usleep(20);
	 		Yesense_data_valid = 0;
	 		//数传电台发送数据
	 		Uartplsend_datalink(DATA_RADIO,g_output_info.location.latitude,g_output_info.location.longtidue,g_output_info.location.altidue);

	 	}
	 	if(Read_AMPLIFIER_Data_Valid == 1) //显示功放EDFA信息
	 	{
 	 		if(*(ReceivedBuffer_AMPLIFIER+8) == 0x80)
	 		{
	 			Read_AMPLIFIER_Power = (((u16)*(ReceivedBuffer_AMPLIFIER+23)) << 8) + (*(ReceivedBuffer_AMPLIFIER+24)); //功放输出功率
	 			Read_PD_Power = (((u16)*(ReceivedBuffer_AMPLIFIER+59)) << 8) + (*(ReceivedBuffer_AMPLIFIER+60));		//PD输入功率检测
	 			SIGNAL_LIGHT_IN_Power = (((u16)*(ReceivedBuffer_AMPLIFIER+18)) << 8) + (*(ReceivedBuffer_AMPLIFIER+19));        //信号输入功率
	 		}

	 		Dw_Data_Write(SIGNAL_BEAM_OUT_DATA_ADDR,(int16_t)Read_AMPLIFIER_Power,4);
	 		usleep(20);
	 		Dw_Data_Write(PD_IN_ADDR,(int16_t)Read_PD_Power,4);
	 		usleep(20);
	 		Dw_Data_Write(SIGNAL_LIGHT_IN_ADDR,(int16_t)SIGNAL_LIGHT_IN_Power,4);
	 		usleep(20);
	 		Read_AMPLIFIER_Data_Valid = 0;
	 		EDFA_ReadAll(EDFA_AMPLIFIER);
	 	}
	 	if(Read_LIGHT_Data_Valid == 1) //显示光源信息
	 	{
	 		if(*(ReceivedBuffer_LIGHT+8) == 0x80)
	 		{
	 			Read_LIGHT_Power = (((u16)*(ReceivedBuffer_LIGHT+23)) << 8) + (*(ReceivedBuffer_LIGHT+24)); //光源输出功率
	 		}

	 		Dw_Data_Write(BEACON_BEAM_OUT_DATA_ADDR,(int16_t)Read_LIGHT_Power,4);
	 		usleep(20);
	 		Read_LIGHT_Data_Valid = 0;
	 		EDFA_ReadAll(EDFA_LIGHT);
	 	}
	 	if(Read_DATA_RADIO_Data_Valid == 1) //获取对方航姿信息
	 	{
	 		Peer_latitude_Temp = ((u32)*(ReceivedBuffer_DATA_RADIO+3) << 24) + ((u32)*(ReceivedBuffer_DATA_RADIO+4) << 16)
	 							+ ((u32)*(ReceivedBuffer_DATA_RADIO+5) << 8) + ((u32)*(ReceivedBuffer_DATA_RADIO+6));  //经度
	 		Peer_longtidue_Temp = ((u32)*(ReceivedBuffer_DATA_RADIO+7) << 24) + ((u32)*(ReceivedBuffer_DATA_RADIO+8) << 16)
	 			 				+ ((u32)*(ReceivedBuffer_DATA_RADIO+9) << 8) + ((u32)*(ReceivedBuffer_DATA_RADIO+10));  //维度
	 		Peer_altidue_Temp = ((u32)*(ReceivedBuffer_DATA_RADIO+11) << 24) + ((u32)*(ReceivedBuffer_DATA_RADIO+12) << 16)
	 			 			 	+ ((u32)*(ReceivedBuffer_DATA_RADIO+9) << 13) + ((u32)*(ReceivedBuffer_DATA_RADIO+14));  //高度
	 		//计算的到实际经纬高
	 		Peer_latitude = (double)Peer_latitude_Temp / 1000000;
	 		Peer_longtidue = (double)Peer_longtidue_Temp / 1000000;
	 		Peer_altidue = (double)Peer_altidue_Temp/1000000;
	 		//显示到迪文屏上
	 		Dw_Data_Write(O_ATT_DIM_ADDR,Peer_latitude*1000,4);
	 		usleep(20);
	 		Dw_Data_Write(O_ATT_LON_ADDR,Peer_longtidue*1000,4);
	 		usleep(20);
	 		Dw_Data_Write(O_ATT_H_ADDR,Peer_altidue*1000,4);
	 		usleep(20);
	 		Read_DATA_RADIO_Data_Valid = 0;


	 	}
	 	if(COARSE_CAMERA_Mark == 1) //开启粗跟踪相机
	 	{
	 		Dw_Data_Write(COARSE_CAMERA_FPS_ADDR,(u16)Speed_Coarse,2);
	 		usleep(20);
	 	}
	 	if(FINE_CAMERA_Mark == 1) //开启精跟踪相机
	 	{
	 		Dw_Data_Write(FINE_CAMERA_FPS_ADDR,(u16)Speed_Fine,2);
	 		usleep(20);
	 	}


	 }
 }


