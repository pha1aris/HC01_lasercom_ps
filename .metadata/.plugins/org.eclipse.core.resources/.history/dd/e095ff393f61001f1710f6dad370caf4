 /*
  * 迪文屏界面控制
  * */
 void Dw_Systems_Control()
 {
	 u16 		Dw_Out_Addr;
	 int32_t	Dw_Out_Data;

	 if(Dw_Read_Data_valid) //迪文屏数据有效
	 {
		 Dw_Read_Data_valid = 0; //数据失效
		 Dw_Data_Read(Dw_Read_Data,&Dw_Out_Addr,&Dw_Out_Data);//对迪文屏发送的数据进行解码

		 //根据迪文屏地址和数据进行模块控制
		 switch(Dw_Out_Addr)
		 {
		 	 case COARSE_CAMERA_ADDR:	//粗跟踪相机
		 		 if(Dw_Out_Data == OPEN_COARSE_CAMERA_DATA) //开启粗跟踪相机
		 		 {
		 			COARSE_CAMERA_Mark = 1;
		 		 }
		 		 else if(Dw_Out_Data == CLOSE_COARSE_CAMERA_DATA)//关闭粗跟踪相机
		 		 {
		 			COARSE_CAMERA_Mark = 0;
		 		 }
		 		 break;
		 	 case FINE_CAMERA_ADDR:	//精跟踪相机
		 		 if(Dw_Out_Data == OPEN_FINE_CAMERA_DATA) //开启精跟踪相机
		 			FINE_CAMERA_Mark = 1;
		 		 else if(Dw_Out_Data == CLOSE_FINE_CAMERA_DATA)//关闭精跟踪相机
		 			FINE_CAMERA_Mark = 0;
		 		 break;
		 	 case COARSE_TRA_ADDR: //粗跟踪
		 		 if(Dw_Out_Data == START_COARSE_TRA_DATA) //开启粗跟踪
		 		 {
		 			COARSE_TRA_Mark = 1;
		 			Elmo_Speed_Model(); //设置速度模式
		 		 }
		 		 else if(Dw_Out_Data == STOP_COARSE_TRA_DATA)//关闭粗跟踪
		 		 {
		 			COARSE_TRA_Mark = 0;
		 			//设置电机速度为0
		 			Elmo_Set_Speed(MOTO_Y_ID,0);
		 			Elmo_Set_Speed(MOTO_X_ID,0);
		 		 }
		 		 break;
		 	 case FINE_TRA_ADDR: //精跟踪
		 		 if(Dw_Out_Data == START_FINE_TRA_DATA) //开启精跟踪
		 		 {
		 			FINE_TRA_Mark = 1;
		 		 }
		 		 else if(Dw_Out_Data == STOP_FINE_TRA_DATA)//关闭精跟踪
		 		 {
		 			FINE_TRA_Mark = 0;
		 		 }
		 		 break;
		 	 case BEACON_BEAM_ADDR: //信标光
		 		 if(Dw_Out_Data == OPEN_BEACON_BEAM_DATA) //开泵
		 		 {
		 			EDFA_On(EDFA_LIGHT);
		 		 }
		 		 else if(Dw_Out_Data == CLOSE_BEACON_BEAM_DATA) //关泵
		 		 {
		 			EDFA_Off(EDFA_LIGHT);
		 		 }
		 		 break;
		 	 case SIGNAL_LIGHT_ADDR: //信号光
		 		 if(Dw_Out_Data == OPEN_SIGNAL_LIGHT_DATA) //开泵
		 		 {
		 			EDFA_On(EDFA_AMPLIFIER);
		 		 }
		 		 else if(Dw_Out_Data == CLOSE_SIGNAL_LIGHT_DATA)	//关泵
		 		 {
		 			EDFA_Off(EDFA_AMPLIFIER);
		 		 }
		 		 break;
		 	 case MOTOR_ADDR: //电机
		 		 if(Dw_Out_Data == MOTOR_ENABLE_DATA) //电机使能
		 		 {
		 			Elmo_StartServe();
		 		 }
		 		 else if(Dw_Out_Data == MOTOR_DISENABLE_DATA)//电机失能
		 		 {
		 			Elmo_StopServe();
		 		 }
		 		 break;
		 	 case STAB_ADDR://稳定
		 		 if(Dw_Out_Data == START_STAB_DATA) //开始稳定
		 		 {
		 			STAB_Mark = 1;
		 		 }
		 		 else if(Dw_Out_Data == STOP_STAB_DATA) //停止稳定
		 		 {
		 			STAB_Mark = 0;
		 		 }
		 		 break;
		 	 case MOTOR_MODE_ADDR://电机模式
		 		 if(Dw_Out_Data == MOTOR_MODE_V_DATA) //速度模式
		 		 {
		 			 Elmo_Speed_Model();
		 		 }
		 		 else if(Dw_Out_Data == MOTOR_MODE_P_DATA)	//位置模式
		 		 {
		 			Elmo_Position_Model();
		 		 }
		 		 break;
		 	 case BEACON_BEAM_OUT_ADDR://信标光输出
		 		Out_data = Dw_Out_Data;
		 		EDFA_Set_Light_Power(EDFA_LIGHT,Out_data);
		 		break;
		 	 case SIGNAL_LIGHT_OUT_ADDR: //信号光输出
		 		Out_data = Dw_Out_Data;
		 		EDFA_SetPower(EDFA_AMPLIFIER,Out_data);
		 		break;
		 	 case MOTOR_POINT_X_ADDR://电机指向X
		 		Elmo_Position_Model_X(); //设置位置模式
		 		Elmo_Set_Position(MOTO_X_ID,(double)Dw_Out_Data/1000); //指向
		 		break;
		 	case MOTOR_POINT_Y_ADDR: //电机指向Y
		 		Elmo_Position_Model_Y(); //设置位置模式
		 		Elmo_Set_Position(MOTO_Y_ID,(double)Dw_Out_Data/1000); //指向
		 		break;
		 	case MOTOR_UP_ADDR://电机运动——上
		 		if(Dw_Out_Data == MOTOR_UP_START_DATA)
		 		{
		 			Elmo_Speed_Model();
		 			Elmo_Set_Speed(MOTO_Y_ID,10);
		 		}
		 		else if(Dw_Out_Data == MOTOR_UP_STOP_DATA)
		 		{
		 			Elmo_Set_Speed(MOTO_Y_ID,0);
		 		}
		 		break;
		 	case MOTOR_DOWN_ADDR://电机运动——下
		 		if(Dw_Out_Data == MOTOR_DOWN_START_DATA)
		 		{
		 			Elmo_Speed_Model();
		 			Elmo_Set_Speed(MOTO_Y_ID,-10);
		 		}
		 		else if(Dw_Out_Data == MOTOR_DOWN_STOP_DATA)
		 		{
		 			Elmo_Set_Speed(MOTO_Y_ID,0);
		 		}
		 		break;
		 	case MOTOR_RIGHT_ADDR://电机运动——右
		 		if(Dw_Out_Data == MOTOR_RIGHT_START_DATA)
		 		{
		 			Elmo_Speed_Model();
		 			Elmo_Set_Speed(MOTO_X_ID,10);
		 		}
		 		else if(Dw_Out_Data == MOTOR_RIGHT_STOP_DATA)
		 		{
		 			Elmo_Set_Speed(MOTO_X_ID,0);
		 		}
		 		break;
		 	case MOTOR_LEFT_ADDR://电机运动——左
		 		if(Dw_Out_Data == MOTOR_LEFT_START_DATA)
		 		{
		 			Elmo_Speed_Model();
		 			Elmo_Set_Speed(MOTO_X_ID,-10);
		 		}
		 		else if(Dw_Out_Data == MOTOR_LEFT_STOP_DATA)
		 		{
		 			Elmo_Set_Speed(MOTO_X_ID,0);
		 		}
		 		break;
		 	case PZT_OUT_X_ADDR://振镜电压输出X
		 		fine_camera_out_x = (float)Dw_Out_Data/1000;
		 		Set_PZT_X_Out(fine_camera_out_x);
		 		break;
		 	case PZT_OUT_Y_ADDR://振镜电压输出Y
		 		fine_camera_out_y = (float)Dw_Out_Data/1000;
		 		Set_PZT_Y_Out(fine_camera_out_y);
		 		break;
		 	case COARSE_CAMERA_THR_ADDR://粗跟踪跟踪阈值
		 		COARSE_CAMERA_THR = Dw_Out_Data;
		 		Set_Coaser_Threshold(COARSE_CAMERA_THR);
		 		break;
		 	case COARSE_CAMERA_TRA_X_ADDR://粗跟踪跟踪中心X
		 		COARSE_CAMERA_TRA_X = Dw_Out_Data;
		 		break;
		 	case COARSE_CAMERA_TRA_Y_ADDR://粗跟踪跟踪中心Y
		 		COARSE_CAMERA_TRA_Y = Dw_Out_Data;
		 		break;
		 	case FINE_CAMERA_THR_ADDR://精跟踪跟踪阈值
		 		FINE_CAMERA_THR = Dw_Out_Data;
		 		Set_Fine_Threshold(FINE_CAMERA_THR);
		 		break;
		 	case FINE_CAMERA_TRA_X_ADDR://精跟踪跟踪中心X
		 		FINE_CAMERA_TRA_X = Dw_Out_Data;
		 		break;
		 	case FINE_CAMERA_TRA_Y_ADDR://精跟踪跟踪中心Y
		 		FINE_CAMERA_TRA_Y = Dw_Out_Data;
		 		break;
		 	case COARSE_CAMERA_TRA_PX_ADDR://粗跟踪参数Px
		 		coarse_camera_Px = (double)Dw_Out_Data/100;
		 		break;
		 	case COARSE_CAMERA_TRA_IX_ADDR://粗跟踪参数Ix
		 		coarse_camera_Ix = (double)Dw_Out_Data/100;
		 		break;
		 	case COARSE_CAMERA_TRA_DX_ADDR://粗跟踪参数Dx
		 		coarse_camera_Dx = (double)Dw_Out_Data/100;
		 		break;
		 	case COARSE_CAMERA_TRA_PY_ADDR://粗跟踪参数Py
		 		coarse_camera_Py = (double)Dw_Out_Data/100;
		 		break;
		 	case COARSE_CAMERA_TRA_IY_ADDR://粗跟踪参数Iy
		 		coarse_camera_Iy = (double)Dw_Out_Data/100;
		 		break;
		 	case COARSE_CAMERA_TRA_DY_ADDR://粗跟踪参数Dy
		 		coarse_camera_Dy = (double)Dw_Out_Data/100;
		 		break;
		 	case FINE_CAMERA_TRA_PX_ADDR://精跟踪参数Px
		 		fine_camera_Px = (double)Dw_Out_Data/100;
		 		break;
		 	case FINE_CAMERA_TRA_IX_ADDR://精跟踪参数Ix
		 		fine_camera_Ix = (double)Dw_Out_Data/100;
		 		break;
		 	case FINE_CAMERA_TRA_DX_ADDR://精跟踪参数Dx
		 		fine_camera_Dx = (double)Dw_Out_Data/100;
		 		break;
		 	case FINE_CAMERA_TRA_PY_ADDR://精跟踪参数Py
		 		fine_camera_Py = (double)Dw_Out_Data/100;
		 		break;
		 	case FINE_CAMERA_TRA_IY_ADDR://精跟踪参数Iy
		 		fine_camera_Iy = (double)Dw_Out_Data/100;
		 		break;
		 	case FINE_CAMERA_TRA_DY_ADDR://精跟踪参数Dy
		 		fine_camera_Dy = (double)Dw_Out_Data/100;
		 		break;
		 	case SDI_CHOICE_ADDR://SDI显示选择
		 		if(Dw_Out_Data == SDI_CHOICE_COARSE) //显示粗跟踪相机图像
		 		{
		 			Sdi_Show_Choice(0);
		 		}
		 		else if(Dw_Out_Data == SDI_CHOICE_FINE) //显示精跟踪相机图像
		 		{
		 			Sdi_Show_Choice(1);
		 		}
		 		break;
		 	case START_POINT_ADDR: //初始指向
		 		Start_Point_Mark = 1;
		 		Elmo_Position_Model(); //设置位置模式
		 		Elmo_Set_Position(MOTO_X_ID,0); //初始指向X
		 		Elmo_Set_Position(MOTO_Y_ID,0); //初始指向y
		 		break;
		 	case SCAN_ADDR://扫描标志
		 		if(Dw_Out_Data == START_SCAN_ADDR) //开始扫描
		 		{
		 			Start_Scan_Mark = 1;
		 			Scan_X_Satrt = Motor_X_Position - Scan_Step*Scan_Num/2;
		 			Scan_Y_Satrt = Motor_Y_Position - Scan_Step*Scan_Num/2;
		 			Scan_X_Point = Scan_X_Satrt;
		 			Scan_Y_Point = Scan_Y_Satrt;
		 			Scan_X_Cnt = 0;
		 			Scan_Y_Cnt = 0;
		 		}
		 		else if(Dw_Out_Data == STOP_SCAN_ADDR) //停止扫描
		 		{
		 			Start_Scan_Mark = 0;
		 		}
		 	case COARSE_CAMERA_WIDTH_ADDR://更改粗相机跟踪宽度
		 		Coarse_Camera_ROI_Set(Coarse_ROI_Width_Par,Dw_Out_Data,Coarse_ROI_Height_Par,Coarse_ROI_Height);
		 		Dw_Data_Write(COARSE_CAMERA_WIDTH_ADDR,Coarse_ROI_Width,2);
		 		break;
		 	case COARSE_CAMERA_HEIGHT_ADDR://更改粗相机跟踪高度
		 		Coarse_Camera_ROI_Set(Coarse_ROI_Width_Par,Coarse_ROI_Width,Coarse_ROI_Height_Par,Dw_Out_Data);
		 		Dw_Data_Write(COARSE_CAMERA_HEIGHT_ADDR,Coarse_ROI_Height,2);
		 		break;
		 	case COARSE_CAMERA_WIDTH_PAR_ADDR://更改粗相机宽度偏置
		 		Coarse_Camera_ROI_Set(Dw_Out_Data,Coarse_ROI_Width,Coarse_ROI_Height_Par,Coarse_ROI_Height);
		 		Dw_Data_Write(COARSE_CAMERA_WIDTH_PAR_ADDR,Coarse_ROI_Width_Par,2);
		 		break;
		 	case COARSE_CAMERA_HEIGHT_PAR_ADDR://更改粗相机高度偏置
		 		Coarse_Camera_ROI_Set(Coarse_ROI_Width_Par,Coarse_ROI_Width,Dw_Out_Data,Coarse_ROI_Height);
		 		Dw_Data_Write(COARSE_CAMERA_HEIGHT_PAR_ADDR,Coarse_ROI_Height_Par,2);
		 		break;
		 	case COARSE_CAMERA_EXTIME_ADDR://更改粗跟踪相机曝光时间
		 		Coarse_Camera_ExSet(Dw_Out_Data);
		 		Dw_Data_Write(COARSE_CAMERA_EXTIME_ADDR,Coarse_Camera_Extime,4);
		 		break;
		 	case FINE_CAMERA_WIDTH_ADDR://更改精相机跟踪宽度
		 		Fine_Camera_ROI_Set(Fine_ROI_Width_Par,Dw_Out_Data,Fine_ROI_Height_Par,Fine_ROI_Height);
		 		Dw_Data_Write(FINE_CAMERA_WIDTH_ADDR,Fine_ROI_Width,2);
		 		break;
		 	case FINE_CAMERA_HEIGHT_ADDR://更改精相机跟踪高度
		 		Fine_Camera_ROI_Set(Fine_ROI_Width_Par,Fine_ROI_Width,Fine_ROI_Height_Par,Dw_Out_Data);
		 		Dw_Data_Write(FINE_CAMERA_HEIGHT_ADDR,Fine_ROI_Height,2);
		 		break;
		 	case FINE_CAMERA_WIDTH_PAR_ADDR://更改精相机宽度偏置
		 		Fine_Camera_ROI_Set(Dw_Out_Data,Fine_ROI_Width,Fine_ROI_Height_Par,Fine_ROI_Height);
		 		Dw_Data_Write(FINE_CAMERA_WIDTH_PAR_ADDR,Fine_ROI_Width_Par,2);
		 		break;
		 	case FINE_CAMERA_HEIGHT_PAR_ADDR://更改精相机高度偏置
		 		Fine_Camera_ROI_Set(Fine_ROI_Width_Par,Fine_ROI_Width,Dw_Out_Data,Fine_ROI_Height);
		 		Dw_Data_Write(FINE_CAMERA_HEIGHT_PAR_ADDR,Fine_ROI_Height_Par,2);
		 		break;
		 	case FINE_CAMERA_EXTIME_ADDR://更改精跟踪相机曝光时间
		 		Fine_Camera_ExSet(Dw_Out_Data);
		 		Dw_Data_Write(FINE_CAMERA_EXTIME_ADDR,Fine_Camera_Extime,4);
		 		break;
		 	case O_ATT_DIM_ADDR://输入指向维度
		 		Peer_latitude = (double)Dw_Out_Data/1000;
		 		break;
		 	case O_ATT_LON_ADDR://输入指向经度
		 		Peer_longtidue = (double)Dw_Out_Data/1000;
		 		break;
		 	case O_ATT_H_ADDR://输入指向高度
		 		Peer_altidue = (double)Dw_Out_Data/1000;
		 		break;

		 }
		 memset(Dw_Read_Data,0,sizeof(Dw_Read_Data)*sizeof(Dw_Read_Data[0]));
	 }
 }


